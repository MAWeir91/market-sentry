# Market Sentry safe local configuration placeholders.
# Do not put real credentials in this file.
# Current working runtime modes require no credentials.

MARKET_SENTRY_ENV=development
MARKET_SENTRY_LOG_LEVEL=INFO

# Provider selection.
# Default provider is mock.
# fixture and composed_fixture are offline.
# alpaca remains a placeholder.
# live_composed remains reserved, gated, and inactive as a scanner provider.
# MARKET_SENTRY_PROVIDER=mock
# MARKET_SENTRY_PROVIDER=fixture
# MARKET_SENTRY_PROVIDER=composed_fixture
# MARKET_SENTRY_PROVIDER=live_composed

# Future live-readiness preflight placeholders only.
# MARKET_SENTRY_ALLOW_LIVE_DATA=true is only a local readiness gate today.
# Setting live env vars does not activate live scanning yet.
# The readiness preflight is no-network:
# python -m market_sentry --live-readiness
# RVOL readiness requires the explicit CLI signal:
# python -m market_sentry --live-readiness --relative-volume-configured
# MARKET_SENTRY_ALLOW_LIVE_DATA=false
# MARKET_SENTRY_WATCHLIST=AAPL,MSFT

# Future provider placeholders only. Do not commit real secrets.
# These values are not required for current working modes and are not used for live API calls yet.
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# ALPACA_DATA_FEED=iex
# FMP_API_KEY=

# No brokerage credentials or order-routing settings are used by Market Sentry.
