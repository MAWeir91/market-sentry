# Market Sentry safe local configuration placeholders.
# Do not put real credentials in this file.

MARKET_SENTRY_ENV=development
MARKET_SENTRY_LOG_LEVEL=INFO

# Provider selection skeleton. Mock is the default and requires no credentials.
# Offline fixture mode is also available for future-provider testing.
# Real Alpaca/FMP provider implementation is not present yet.
MARKET_SENTRY_PROVIDER=mock
# MARKET_SENTRY_PROVIDER=fixture
MARKET_SENTRY_WATCHLIST=

# Future provider placeholders only. Do not commit real secrets.
# These values are not required for mock mode and are not used for live API calls yet.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DATA_FEED=iex
FMP_API_KEY=

# No brokerage credentials or order-routing settings are used by Market Sentry.
